{
	"name": "n8n-nodes-decoupled-io",
	"version": "0.1.2",
	"description": "n8n community node for Decoupled.io — read and write Drupal content, manage spaces and environment tiers, trigger workflows from content events.",
	"license": "MIT",
	"homepage": "https://decoupled.io/docs/integrations/n8n",
	"keywords": [
		"n8n-community-node-package",
		"decoupled-io",
		"decoupled",
		"drupal",
		"headless-cms",
		"cms",
		"graphql",
		"jsonapi"
	],
	"author": {
		"name": "Decoupled.io",
		"email": "hello@decoupled.io"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/nextagencyio/n8n-nodes-decoupled-io.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist/credentials/**/*.{js,svg}",
		"dist/nodes/**/*.{js,svg}",
		"dist/package.json"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/DecoupledIoApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/DecoupledDrupal/DecoupledDrupal.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.0.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
